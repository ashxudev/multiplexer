{
  "name": "multiplexer-electron",
  "version": "0.1.0",
  "description": "Desktop app for batch molecular docking with Boltz Lab",
  "author": "Multiplexer contributors",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "mkdir -p public && cp node_modules/@rdkit/rdkit/dist/RDKit_minimal.wasm public/RDKit_minimal.wasm",
    "dist:mac": "set -a && [ -f .env.local ] && . .env.local; set +a && electron-vite build && electron-builder --mac",
    "dist": "set -a && [ -f .env.local ] && . .env.local; set +a && electron-vite build && electron-builder",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:e2e:fast": "bash scripts/run-e2e.sh --grep @fast",
    "test:e2e:api": "bash scripts/run-e2e.sh --grep @api"
  },
  "dependencies": {
    "@aptabase/electron": "^0.3.1",
    "@rdkit/rdkit": "2025.3.4-1.0.0",
    "@sentry/electron": "^7.10.0",
    "@tanstack/react-query": "^5.64.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.19",
    "@trpc/client": "^11.1.0",
    "@trpc/react-query": "^11.1.0",
    "@trpc/server": "^11.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.575.0",
    "molstar": "^5.6.1",
    "p-limit": "^6.2.0",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^3.5.0",
    "tar": "^7.4.3",
    "trpc-electron": "0.1.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}